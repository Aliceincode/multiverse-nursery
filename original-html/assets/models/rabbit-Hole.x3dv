source DEF MusicClip2 AudioClip {
url "RabbitHole/vrml/om.wav"
description "Fire"
loop TRUE
},
location 0 -390 0
minFront 5
minBack  5
maxFront 150
maxBack  150
intensity .3
spatialize FALSE
}
