#VRML V2.0 utf8
WorldInfo
{
	title	"minigrok-caves"
	info	"Aliceincode"
}
NavigationInfo
{
	type [ "WALK"  "ANY" ]
	headlight	TRUE
	speed		1.000000
}

DEF Enter Viewpoint{
	position -5 -1.5 -12
	orientation 0.0 1.0 0.0 2.8
	description "Caves Entrance"
	jump TRUE
}
DEF DownTheHole Viewpoint{
	position 2 -405 0
	orientation 0.0 1.0 0.0 0
	fieldOfView 1.5 
	description "Rabbit Hole"
	jump TRUE
}
PointLight {
	location -8 -3.25 -8
	intensity 1
	color 1 0 0	
}
PointLight {
	location -8 -400 -8
	intensity 1
	color 1 1 1	
}
# Prebuilt scene lighting
# 4 light version
DEF L1 DirectionalLight {
 intensity 0.4
 direction -.9437 -.2972 .1451
 color 1 0 0
}
DEF L2 DirectionalLight {
 intensity 0.8
 direction .3255 -.3316 -.8855
 color 1 0 0
}
DEF L3 DirectionalLight {
 intensity 0.4
 direction .755 -.252 .6054
}
DEF L4 DirectionalLight {
 intensity 0.3
 direction .1013 .9948 .003768
}
Background{
	skyColor[ 0.0 0.0 0.0
	]
	skyAngle [ 1.309, 1.571]
	groundColor[
		0 0 0
	]
	groundAngle [1.309, 1.571]
	frontUrl ["RabbitHole/vrml/images/space_1_front.jpg"]
	backUrl ["RabbitHole/vrml/images/space_1_back.jpg"]
	leftUrl ["RabbitHole/vrml/images/space_1_left.jpg"]
	rightUrl ["RabbitHole/vrml/images/space_1_right.jpg"]
	topUrl ["RabbitHole/vrml/images/space_1_top.jpg"]
	bottomUrl ["RabbitHole/vrml/images/space_1_bottom.jpg"]
}
Fog {
	fogType "LINEAR"
	visibilityRange 180
	color 0.1 0.1 0.1
}
Background {
	skyColor 1 0 0
}
