DEF roots Transform {
	children [
		Transform {
			translation	-4.5 -3.7 2
			scale 4 4 4
			children [	 Inline	{ url "RabbitHole/vrml/treeRoot.wrz" }
			]
		} 
		Transform {
			translation	-55.5 -411 -25
			rotation 0 1 0 3.14
			scale 4 4 4
			children [	 Inline	{ url "RabbitHole/vrml/treeRoot.wrz" }
			]
		} 
	]
}
