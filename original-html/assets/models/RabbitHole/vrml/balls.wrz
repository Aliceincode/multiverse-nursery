DEF loadurl Script{
eventIn SFTime click
field MFString target "target=new"
field MFString page
"http://woopwoop.8illusion.net/3d/worlds/gardenOfTruth.wrl"
url "javascript:
function click(value){
if(value)
Browser.loadURL(page,target); //notice these are the MFString
}//end function
"
}#end script ] 
]ROUTE enter.touchTime TO loadurl.click
} ] 
} ] 
} 	 ] 
}
